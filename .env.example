# ============================================================
# Ice Cola Docker Deployment — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values before deploying:
#   cp .env.example .env
#   docker compose up -d
# ============================================================

# ==========================================
# Ports
# ==========================================
ADMIN_PORT=80
SERVER_PORT=3000
POSTGRES_PORT=5433
HERMES_DASHBOARD_PORT=9119

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=icecola

# ==========================================
# JWT (REQUIRED — generate strong secrets)
# ==========================================
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# AI Encryption Key (REQUIRED — 64 hex chars)
# ==========================================
# Generate: openssl rand -hex 32
AI_ENCRYPTION_KEY=change-me-to-64-hex-characters

# ==========================================
# Hermes Agent
# ==========================================
HERMES_AGENT_URL=http://host.docker.internal:8642

# ==========================================
# CORS (comma-separated origins)
# ==========================================
CORS_ORIGINS=http://localhost,http://127.0.0.1

# ==========================================
# Email — Resend (optional)
# ==========================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-domain.com
