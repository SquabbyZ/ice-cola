# ============================================
# Server Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Hermes Agent Integration
# ============================================
# URL of the Hermes TUI Gateway WebSocket server
# Default: ws://localhost:8080/api/ws
HERMES_GATEWAY_URL=ws://localhost:8080/api/ws

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openclaw?schema=public

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:1420,http://localhost:5173

# ============================================
# OpenClaw Config Path (Optional)
# ============================================
# OPENCLAW_CONFIG_PATH=/path/to/openclaw.json
