# ============================================
# Server Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Hermes Agent Integration
# ============================================
# URL of the Hermes TUI Gateway WebSocket server
# Default: ws://localhost:8080/api/ws
HERMES_GATEWAY_URL=ws://localhost:8080/api/ws

# ============================================
# Database Configuration
# ============================================
# 本地开发使用原生 PG (5432)，Docker 部署使用映射端口 (5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/icecola?schema=public

# ============================================
# JWT Configuration
# ============================================
# Local development only. Use a strong unique secret in any shared environment.
JWT_SECRET=icecola-local-dev-jwt-secret-not-for-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# AI Model Encryption
# ============================================
# Local development only. Use a unique 64-character hex key in any shared environment.
AI_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# Email Configuration
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:1420,http://localhost:5173

# ============================================
# OpenClaw Config Path (Optional)
# ============================================
# OPENCLAW_CONFIG_PATH=/path/to/openclaw.json
