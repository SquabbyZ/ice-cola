# ============================================================
# Ice Cola Backend Deployment — Environment Variables
# ============================================================
# 使用方法:
#   cp .env.deploy.example .env.deploy
#   # 编辑 .env.deploy 填入实际值
#   docker compose -f docker-compose.deploy.yml --env-file .env.deploy up -d
# ============================================================

# ==========================================
# 必填项
# ==========================================
# PostgreSQL 密码 (必须修改)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT 密钥 (必须修改，建议 64 字符随机字符串)
# 生成: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# AI 模型加密密钥 (必须修改，64 位十六进制)
# 生成: openssl rand -hex 32
AI_ENCRYPTION_KEY=change-me-to-64-hex-characters

# ==========================================
# 端口配置
# ==========================================
# PostgreSQL (容器内 5432，宿主机映射端口)
POSTGRES_PORT=5432

# Server API
SERVER_PORT=3000

# Hermes Dashboard
HERMES_DASHBOARD_PORT=9119

# ==========================================
# 可选项
# ==========================================
# PostgreSQL 用户名
POSTGRES_USER=postgres

# PostgreSQL 数据库名
POSTGRES_DB=icecola

# JWT 过期时间
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# CORS 允许的源 (逗号分隔)
CORS_ORIGINS=http://localhost

# 邮件服务 (Resend，可选)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
